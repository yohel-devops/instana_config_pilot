# Backend Configuration
ENVIRONMENT=development
LOG_LEVEL=info
BACKEND_PORT=8000

# Frontend Configuration
VITE_API_URL=http://localhost:8000

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:80,http://localhost:3000

# File Upload Configuration
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=.yaml,.yml

# Temporary Files
TEMP_DIR=./temp
UPLOAD_DIR=./uploads

# Optional: Instana API Configuration (for future features)
# INSTANA_API_URL=https://your-instana-instance.com
# INSTANA_API_TOKEN=your-api-token